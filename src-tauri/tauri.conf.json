{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-app",
  "version": "0.1.0",
  "identifier": "com.filebox.apple",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FileBox",
        "width": 80,
        "height": 80,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "dashboard",
        "title": "FileBox Dashboard",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true,
        "resizable": true,
        "shadow": true
      },
      {
        "label": "note",
        "title": "Sticky Note",
        "width": 280,
        "height": 280,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": true,
        "shadow": false
      },
      {
        "label": "tray-menu",
        "title": "Tray Menu",
        "width": 180,
        "height": 95,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
